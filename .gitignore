# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify — keep graph.json + GRAPH_REPORT.md; ignore regenerable/local artifacts
graphify-out/cache/
graphify-out/graph.html
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/.graphify_labels.json
graphify-out/.graphify_python
graphify-out/.graphify_root

# Local Claude Code worktrees (regenerable, not source)
.claude/worktrees/
